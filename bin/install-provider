#!/usr/bin/env bash
# Install the Vagrant provider (and its plugin) appropriate for this host.
#   - macOS Apple Silicon  -> qemu (brew) + vagrant-qemu
#   - macOS Intel          -> virtualbox (brew cask)
#   - Linux Debian/Ubuntu  -> libvirt or virtualbox (apt) + vagrant-libvirt
#   - Linux Fedora/RHEL    -> libvirt (dnf) + vagrant-libvirt
#
# Override provider:        PROVIDER=libvirt bin/install-provider
# Skip confirmation prompt: YES=1 bin/install-provider
set -euo pipefail
. "$(dirname "$0")/_lib.sh"

provider="${PROVIDER:-$(default_provider)}"
yes="${YES:-0}"

confirm() {
  [ "$yes" = "1" ] && return 0
  printf '%s [y/N] ' "$1" >&2
  read -r ans || return 1
  case "$ans" in y|Y|yes|YES) return 0 ;; *) return 1 ;; esac
}

run() {
  printf '+ %s\n' "$*" >&2
  "$@"
}

# Detect Linux package manager (lazy — only invoked on linux paths).
linux_pkg_mgr() {
  if   command -v apt-get >/dev/null 2>&1; then printf 'apt\n'
  elif command -v dnf     >/dev/null 2>&1; then printf 'dnf\n'
  elif command -v yum     >/dev/null 2>&1; then printf 'yum\n'
  else die "no supported package manager found (apt/dnf/yum)"
  fi
}

ensure_brew() {
  command -v brew >/dev/null 2>&1 || die "Homebrew is required (https://brew.sh)"
}

install_macos_fusion() {
  if [ -d /Applications/VMware\ Fusion.app ]; then
    info "VMware Fusion already installed."
  else
    cat >&2 <<'MSG'
VMware Fusion can no longer be installed via Homebrew (the cask was disabled
on 2025-06-23 because Broadcom requires an authenticated download).

Manual install:
  1. Create a free Broadcom Support Portal account at https://support.broadcom.com
  2. Navigate to: My Downloads -> VMware Fusion
  3. Download the latest .dmg, mount it, drag VMware Fusion.app into /Applications
  4. Run 'VMware Fusion' once to accept the EULA (free for personal use since Nov 2024)
  5. Re-run 'make setup'
MSG
    die "VMware Fusion not installed"
  fi
  install_plugin vagrant-vmware-desktop
  if ! command -v vmrun >/dev/null 2>&1; then
    info "Note: vmrun not found in PATH. The vagrant-vmware-utility installer should be"
    info "downloaded from https://developer.hashicorp.com/vagrant/install#vmware-utility"
    info "and run once to give Vagrant network access to Fusion."
  fi
}

install_macos_parallels() {
  ensure_brew
  if [ -d /Applications/Parallels\ Desktop.app ]; then
    info "Parallels Desktop already installed."
  else
    confirm "Install Parallels Desktop via 'brew install --cask parallels' (paid software)?" || die "aborted"
    run brew install --cask parallels
  fi
  install_plugin vagrant-parallels
}

install_macos_virtualbox() {
  ensure_brew
  if command -v VBoxManage >/dev/null 2>&1; then
    info "VirtualBox already installed."
  else
    confirm "Install VirtualBox via 'brew install --cask virtualbox' (will prompt for admin password)?" || die "aborted"
    run brew install --cask virtualbox
  fi
}

install_linux_virtualbox() {
  case "$(linux_pkg_mgr)" in
    apt) confirm "Install VirtualBox via 'sudo apt-get install -y virtualbox'?" || die "aborted"
         run sudo apt-get update
         run sudo apt-get install -y virtualbox ;;
    dnf) confirm "Install VirtualBox via 'sudo dnf install -y VirtualBox'?" || die "aborted"
         run sudo dnf install -y VirtualBox ;;
    yum) confirm "Install VirtualBox via 'sudo yum install -y VirtualBox'?" || die "aborted"
         run sudo yum install -y VirtualBox ;;
  esac
}

install_linux_libvirt() {
  case "$(linux_pkg_mgr)" in
    apt) confirm "Install libvirt + qemu-kvm via apt?" || die "aborted"
         run sudo apt-get update
         run sudo apt-get install -y libvirt-daemon-system libvirt-clients libvirt-dev qemu-kvm bridge-utils virtinst ;;
    dnf) confirm "Install libvirt + qemu-kvm via dnf?" || die "aborted"
         run sudo dnf install -y libvirt qemu-kvm libvirt-devel bridge-utils virt-install ;;
    yum) confirm "Install libvirt + qemu-kvm via yum?" || die "aborted"
         run sudo yum install -y libvirt qemu-kvm libvirt-devel bridge-utils virt-install ;;
  esac
  if ! systemctl is-active --quiet libvirtd 2>/dev/null; then
    confirm "Enable and start libvirtd?" && run sudo systemctl enable --now libvirtd || true
  fi
  if ! id -nG "$USER" | tr ' ' '\n' | grep -qx libvirt; then
    confirm "Add $USER to the libvirt group? (log out / back in afterwards)" \
      && run sudo usermod -aG libvirt "$USER" || true
  fi
  install_plugin vagrant-libvirt
}

install_plugin() {
  local plugin=$1
  command -v vagrant >/dev/null 2>&1 || die "vagrant is not installed; install it first (brew install --cask vagrant | sudo apt-get install vagrant)"
  if vagrant plugin list 2>/dev/null | grep -q "^$plugin "; then
    info "$plugin plugin already installed."
  else
    confirm "Install vagrant plugin '$plugin'?" || die "aborted"
    run vagrant plugin install "$plugin"
  fi
}

# Install shell completion for the current $SHELL. Idempotent.
install_shell_completion() {
  local shell_name shell_path
  shell_path="${SHELL:-$(getent passwd "$USER" 2>/dev/null | cut -d: -f7)}"
  shell_name="$(basename "${shell_path:-bash}")"

  case "$shell_name" in
    fish)
      local target="${XDG_CONFIG_HOME:-$HOME/.config}/fish/conf.d/vagrant-machines.fish"
      local source="$REPO_ROOT/completions/vagrant-machines.fish"
      if [ -L "$target" ] && [ "$(readlink "$target")" = "$source" ]; then
        info "fish completion already installed at $target"
        return
      fi
      confirm "Install fish completion (symlink $target -> $source)?" || { info "skipped completion install"; return; }
      run mkdir -p "$(dirname "$target")"
      [ -e "$target" ] && run mv "$target" "$target.bak.$(date +%s)"
      run ln -s "$source" "$target"
      info "fish completion installed; open a new fish shell or 'exec fish' to load it."
      ;;
    bash)
      local rc="$HOME/.bashrc"
      [ "$(uname -s)" = "Darwin" ] && [ -f "$HOME/.bash_profile" ] && rc="$HOME/.bash_profile"
      local line="source $REPO_ROOT/completions/vagrant-machines.bash  # vagrant-machines completion"
      if grep -Fq "$REPO_ROOT/completions/vagrant-machines.bash" "$rc" 2>/dev/null; then
        info "bash completion already sourced from $rc"
        return
      fi
      confirm "Append completion source line to $rc?" || { info "skipped completion install"; return; }
      printf '\n%s\n' "$line" >> "$rc"
      info "bash completion installed; run 'source $rc' or open a new shell to load it."
      ;;
    zsh)
      info "zsh detected. The bash completion script works in zsh via bashcompinit."
      info "Add this to ~/.zshrc:"
      info "  autoload -U +X bashcompinit && bashcompinit"
      info "  source $REPO_ROOT/completions/vagrant-machines.bash"
      ;;
    *)
      info "Unsupported shell '$shell_name' for auto-completion install."
      info "See $REPO_ROOT/completions/ for the available completion scripts."
      ;;
  esac
}

info "Host:     $(host_platform)"
info "Provider: $provider"
echo

case "$(host_platform)::$provider" in
  darwin-arm64::vmware_desktop) install_macos_fusion ;;
  darwin-arm64::parallels)      install_macos_parallels ;;
  darwin-arm64::virtualbox)     die "VirtualBox on Apple Silicon is a dev preview only. Use vmware_desktop (default) or parallels." ;;
  darwin-*::vmware_desktop)     install_macos_fusion ;;
  darwin-*::virtualbox)         install_macos_virtualbox ;;
  darwin-*::parallels)          install_macos_parallels ;;
  linux-*::virtualbox)          install_linux_virtualbox ;;
  linux-*::libvirt)             install_linux_libvirt ;;
  linux-*::qemu)                die "Use libvirt on Linux instead of qemu (libvirt wraps qemu and has full Vagrant support)." ;;
  *)                            die "no installer recipe for $(host_platform) + $provider — install manually" ;;
esac

echo
info "Provider install complete. Now installing shell completion..."
echo
install_shell_completion

echo
info "Done. Run 'make doctor' to verify."
