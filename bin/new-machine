#!/usr/bin/env bash
# Create a new VM dir under .machines/ from the template, wired up for the
# chosen OS / role / provider. All knobs default sensibly; only NAME is required.
#
# Usage:
#   bin/new-machine name=web1 os=ubuntu24 role=server
#   bin/new-machine name=db1  os=rocky10 role=server provider=virtualbox
#   bin/new-machine                  # interactive
set -euo pipefail
. "$(dirname "$0")/_lib.sh"

# Parse k=v args
name=""; os=""; role=""; provider=""; vm_root=".machines"
for arg in "$@"; do
  case "$arg" in
    name=*)     name="${arg#name=}" ;;
    os=*)       os="${arg#os=}" ;;
    role=*)     role="${arg#role=}" ;;
    provider=*) provider="${arg#provider=}" ;;
    vm_root=*)  vm_root="${arg#vm_root=}" ;;
    *) die "unknown arg: $arg (expected name=, os=, role=, provider=, vm_root=)" ;;
  esac
done

prompt() {
  local var=$1 msg=$2
  printf '%s' "$msg" >&2
  read -r "$var"
}

# name
if [ -z "$name" ]; then prompt name "VM name: "; fi
[ -n "$name" ] || die "name is required"
printf '%s' "$name" | grep -Eq '^[A-Za-z0-9._-]+$' || die "name may only contain letters, digits, dot, underscore, dash"

# os
if [ -z "$os" ]; then
  echo "Available OS ids:" >&2
  list_os_ids | nl -w2 -s') ' >&2
  prompt choice "Choose number: "
  os=$(list_os_ids | sed -n "${choice}p")
fi
list_os_ids | grep -Fxq "$os" || die "unknown os: $os"

# role
if [ -z "$role" ]; then
  prompt role "Role [server|workstation] (server): "
  role=${role:-server}
fi
case "$role" in server|workstation) ;; *) die "role must be server or workstation" ;; esac

# provider
[ -n "$provider" ] || provider=$(default_provider)

# resolve catalog
box=$(catalog_box "$os" "$provider") || die "no box for $os on $provider — edit boxes.yaml or pass provider="
ansible_dir=$(catalog_field "$os" ansible)
playbook="ansible-${ansible_dir}-base"
setup_file="setup_${role}.yml"

playbook_path="$REPO_ROOT/provisioners/ansible/$playbook/$role/$setup_file"
[ -f "$playbook_path" ] || die "missing playbook: $playbook_path"

vm_dir="$REPO_ROOT/$vm_root/$name"
[ -e "$vm_dir" ] && die "$vm_dir already exists"

mkdir -p "$REPO_ROOT/$vm_root"
cp -R "$REPO_ROOT/template/." "$vm_dir/"

# Render .vmconfig that the Vagrantfile reads at runtime.
cat > "$vm_dir/.vmconfig" <<EOF
MACHINE_NAME=$name
VAGRANT_BOX=$box
VAGRANT_PROVIDER=$provider
ANSIBLE_PLAYBOOK=$playbook
ANSIBLE_ROLE=$role
ANSIBLE_SETUP_FILE=$setup_file
EOF

ln -sf ../../provisioners/ansible "$vm_dir/ansible"

cat <<EOF
Created $vm_dir
  os:        $os
  box:       $box
  provider:  $provider
  role:      $role
  playbook:  $playbook/$role/$setup_file

Bring it up with:
  make up name=$name
  make ssh name=$name
  make destroy name=$name
EOF
