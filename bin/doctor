#!/usr/bin/env bash
# Check that the host has what it needs to bring up VMs.
set -euo pipefail
. "$(dirname "$0")/_lib.sh"

provider=$(default_provider)
platform=$(host_platform)
status=0

info "Platform: $platform"
info "Default provider: $provider"
echo

check_cmd() {
  if command -v "$1" >/dev/null 2>&1; then
    info "  ok   $1"
  else
    info "  MISS $1${2:+   ($2)}"
    status=1
  fi
}

check_plugin() {
  if vagrant plugin list 2>/dev/null | grep -q "^$1 "; then
    info "  ok   plugin: $1"
  else
    info "  MISS plugin: $1${2:+   ($2)}"
    status=1
  fi
}

info "Required CLIs:"
check_cmd vagrant   "brew install --cask vagrant   |   sudo apt install vagrant"
check_cmd ansible   "brew install ansible          |   sudo apt install ansible"
check_cmd python3   "preinstalled on macOS / linux"
python3 -c 'import yaml' 2>/dev/null && info "  ok   python3 yaml" || { info "  MISS python3 yaml   (pip3 install pyyaml)"; status=1; }

echo
info "Provider ($provider) prerequisites:"
case "$provider" in
  virtualbox)
    check_cmd VBoxManage "brew install --cask virtualbox   |   sudo apt install virtualbox"
    ;;
  libvirt)
    check_cmd virsh "sudo apt install libvirt-clients libvirt-daemon-system qemu-kvm"
    check_plugin vagrant-libvirt "vagrant plugin install vagrant-libvirt"
    ;;
  qemu)
    check_cmd qemu-system-aarch64 "brew install qemu"
    check_plugin vagrant-qemu "vagrant plugin install vagrant-qemu"
    info "  note  qemu provider boxes are sparse; many publishers mislabel libvirt boxes as qemu."
    ;;
  parallels)
    check_cmd prlctl "install Parallels Desktop"
    check_plugin vagrant-parallels "vagrant plugin install vagrant-parallels"
    ;;
  utm)
    check_cmd UTM "install UTM from utmapp.com or 'brew install --cask utm'"
    check_plugin vagrant_utm "vagrant plugin install vagrant_utm"
    ;;
esac

echo
if [ $status -eq 0 ]; then
  info "All checks passed."
else
  info "Some checks failed. Run 'make setup' to install the provider for your platform,"
  info "or follow the hints above."
  exit 1
fi
