# -*- mode: ruby -*-
# vi: set ft=ruby :
#
# Provider-agnostic template. Reads .vmconfig (written by bin/new-machine).

require 'pathname'

CONFIG_PATH = Pathname.new(__dir__).join('.vmconfig').freeze
abort "missing #{CONFIG_PATH} (was this dir created via bin/new-machine?)" unless CONFIG_PATH.file?

cfg = {}
CONFIG_PATH.each_line do |line|
  line = line.strip
  next if line.empty? || line.start_with?('#')
  k, v = line.split('=', 2)
  cfg[k] = v
end

MACHINE_NAME       = cfg.fetch('MACHINE_NAME')
VAGRANT_BOX        = cfg.fetch('VAGRANT_BOX')
VAGRANT_PROVIDER   = cfg.fetch('VAGRANT_PROVIDER')
VAGRANT_ARCH       = cfg['VAGRANT_ARCH']
ANSIBLE_PLAYBOOK   = cfg.fetch('ANSIBLE_PLAYBOOK')
ANSIBLE_ROLE       = cfg.fetch('ANSIBLE_ROLE')
ANSIBLE_SETUP_FILE = cfg.fetch('ANSIBLE_SETUP_FILE')

CPUS    = Integer(ENV.fetch('VM_CPUS', '2'))
MEMORY  = Integer(ENV.fetch('VM_MEMORY', '4096'))

PROVISIONERS_PATH = File.expand_path('../../provisioners/ansible', __dir__).freeze

Vagrant.configure(2) do |config|
  config.vm.box = VAGRANT_BOX
  config.vm.box_architecture = VAGRANT_ARCH if VAGRANT_ARCH && !VAGRANT_ARCH.empty?
  config.vm.hostname = MACHINE_NAME
  # Mount the repo's provisioners dir into the guest at a stable path so
  # ansible_local can find playbooks regardless of which VM dir we're in.
  config.vm.synced_folder PROVISIONERS_PATH, '/srv/ansible'

  case VAGRANT_PROVIDER
  when 'virtualbox'
    config.vm.network :private_network, type: 'dhcp'
    config.vm.provider 'virtualbox' do |v|
      v.gui = false
      v.name = MACHINE_NAME
      v.cpus = CPUS
      v.memory = MEMORY
    end
  when 'libvirt'
    config.vm.provider 'libvirt' do |v|
      v.uri = 'qemu:///session'
      v.qemu_use_session = true
      v.cpus = CPUS
      v.memory = MEMORY
    end
  when 'parallels'
    config.vm.provider 'parallels' do |v|
      v.cpus = CPUS
      v.memory = MEMORY
    end
  when 'vmware_desktop'
    config.vm.provider 'vmware_desktop' do |v|
      v.cpus = CPUS
      v.memory = MEMORY
    end
  else
    abort "unsupported provider: #{VAGRANT_PROVIDER}"
  end

  config.vm.provision 'ansible_local' do |a|
    a.provisioning_path = '/srv/ansible'
    a.playbook = "#{ANSIBLE_PLAYBOOK}/#{ANSIBLE_ROLE}/#{ANSIBLE_SETUP_FILE}"
    a.compatibility_mode = '2.0'
    # Install Ansible via pip rather than the ansible/ansible PPA so we don't
    # leave a stale apt source behind that makes future apt updates flaky
    # when launchpad is slow/unreachable.
    a.install_mode = 'pip'
  end
end
